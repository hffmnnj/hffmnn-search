# Required: Brave Search API key from https://api.search.brave.com
BRAVE_API_KEY=your_b...here

# Optional: Exa Neural Search API key from https://exa.ai (secondary / fallback search)
EXA_API_KEY=your_x...here

# ── LLM Configuration ────────────────────────────────────────────────────────
# Option A: Use any OpenAI/Anthropic-compatible endpoint
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4o

# Option B: Ollama Cloud (native, used as fallback if LLM_* not set)
OLLAMA_API_KEY=your_o...here

# Optional: override default port
PORT=6767
