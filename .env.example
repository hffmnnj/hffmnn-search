# ── Search Provider ────────────────────────────────────────────────────────────
# Choose your search backend: 'brave' (default) or 'exa'
SEARCH_PROVIDER=brave

# Required for Brave Search
BRAVE_API_KEY=***

# Required for Exa Neural Search (if SEARCH_PROVIDER=exa)
EXA_API_KEY=***

# ── LLM Configuration ──────────────────────────────────────────────────────────
# Option A: Any OpenAI/Anthropic-compatible endpoint (OpenRouter, local vLLM, etc.)
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL=gpt-5.5

# Option B: Ollama Cloud (native) — used automatically if LLM_BASE_URL is unset
OLLAMA_API_KEY=***

# Optional: override default port
PORT=6767
